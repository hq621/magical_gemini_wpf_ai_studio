<Window x:Class="GeminiWpfAiStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Desktop Authenticator Sync"
        Width="390"
        Height="760"
        MinWidth="330"
        MinHeight="560"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        Topmost="True">
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#2A111111" />
            <Setter Property="CaretBrush" Value="#F8FAFC" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#44111111" />
            <Setter Property="CaretBrush" Value="#F8FAFC" />
        </Style>
        <Style x:Key="TopButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="#26262626" />
            <Setter Property="BorderBrush" Value="#50505050" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource TopButton}">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Background" Value="#55525252" />
            <Setter Property="BorderBrush" Value="#66737373" />
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="8"
            Padding="12"
            CornerRadius="26"
            Background="#4D101010"
            BorderBrush="#445A5A5A"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock" Text="Ready" FontSize="12" Foreground="#CBD5E1" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SettingsButton" Style="{StaticResource TopButton}" Content="设" ToolTip="设置" Click="SettingsButton_Click" />
                    <Button x:Name="StealthButton" Style="{StaticResource TopButton}" Content="隐" ToolTip="隐身/正常模式" Click="StealthButton_Click" />
                    <Button x:Name="AttachButton" Style="{StaticResource TopButton}" Content="截" ToolTip="Ctrl+1 截灰框并发送" Click="AttachButton_Click" />
                    <Button x:Name="FrameEditButton" Style="{StaticResource TopButton}" Content="框" ToolTip="Ctrl+4 调整截图框" Click="FrameEditButton_Click" />
                    <Button x:Name="ClearButton" Style="{StaticResource TopButton}" Content="清" ToolTip="清空对话" Click="ClearButton_Click" />
                    <Button x:Name="PinButton" Style="{StaticResource TopButton}" Content="顶" ToolTip="置顶切换" Click="PinButton_Click" />
                    <Button Style="{StaticResource TopButton}" Content="关" ToolTip="关闭" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Border x:Name="ChatPanelBorder" Background="#12000000" CornerRadius="18" BorderBrush="#333F3F3F" BorderThickness="1">
                    <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Hidden" Padding="10">
                        <ItemsControl x:Name="ChatItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="11"
                                            CornerRadius="14"
                                            Background="{Binding Background}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Role}" FontWeight="Bold" Foreground="{Binding Accent}" Margin="0,0,0,5" />
                                            <TextBox Text="{Binding Text}"
                                                     IsReadOnly="True"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     Background="Transparent"
                                                     Foreground="#F8FAFC"
                                                     TextWrapping="Wrap"
                                                     FontSize="14"
                                                     AcceptsReturn="True" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border x:Name="SettingsPanel"
                        Visibility="Collapsed"
                        Background="#E5101010"
                        CornerRadius="18"
                        BorderBrush="#665B6B83"
                        BorderThickness="1"
                        Padding="14">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <TextBlock Text="设置" FontSize="20" FontWeight="Bold" DockPanel.Dock="Left" />
                                <Button Content="完成" Width="58" Height="30" HorizontalAlignment="Right" Click="SettingsButton_Click" />
                            </DockPanel>

                            <TextBlock Text="模型" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBox x:Name="ModelTextBox" Text="gemini-3.1-flash-lite" Margin="0,0,0,12" />

                            <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,12" />

                            <TextBlock Text="System instruction" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBox x:Name="SystemTextBox"
                                     Text=""
                                     Height="90"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="截图默认提示词" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBox x:Name="ScreenshotPromptTextBox"
                                     Text="请分析这张截图。"
                                     Height="62"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Hidden"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="背景透明度" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <DockPanel Margin="0,0,0,12">
                                <Slider x:Name="ShellOpacitySlider"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="30"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="False"
                                        ValueChanged="ShellOpacitySlider_ValueChanged" />
                                <TextBlock x:Name="OpacityTextBlock" Text="30%" Width="46" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>

                            <CheckBox x:Name="ProxyCheckBox"
                                      Content="使用代理"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      Margin="0,0,0,8" />
                            <TextBlock Text="代理地址" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBox x:Name="ProxyTextBox" Text="http://127.0.0.1:10808" Margin="0,0,0,12" />

                            <CheckBox x:Name="ForceTopmostCheckBox"
                                      Content="低频保活置顶（5秒，无激活）"
                                      IsChecked="True"
                                      Foreground="#F8FAFC"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="生成参数" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Temperature" FontSize="12" Foreground="#CBD5E1" />
                                    <TextBox x:Name="TemperatureTextBox" Text="0.9" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max tokens" FontSize="12" Foreground="#CBD5E1" />
                                    <TextBox x:Name="MaxTokensTextBox" Text="65536" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Thinking level" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ComboBox x:Name="ThinkingLevelComboBox"
                                      SelectedIndex="1"
                                      Background="#2A111111"
                                      Foreground="#F8FAFC"
                                      BorderBrush="#404040"
                                      Margin="0,0,0,12">
                                <ComboBoxItem Content="minimal" />
                                <ComboBoxItem Content="low" />
                                <ComboBoxItem Content="medium" />
                                <ComboBoxItem Content="high" />
                            </ComboBox>

                            <TextBlock Text="聊天框大小" FontWeight="SemiBold" Margin="0,8,0,6" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="宽" FontSize="12" Foreground="#CBD5E1" />
                                    <TextBox x:Name="WindowWidthTextBox" Text="390" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="高" FontSize="12" Foreground="#CBD5E1" />
                                    <TextBox x:Name="WindowHeightTextBox" Text="760" />
                                </StackPanel>
                                <Button Grid.Column="4" Content="应用" Height="34" VerticalAlignment="Bottom" Click="ApplyWindowSizeButton_Click" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="AttachmentBar"
                        Visibility="Collapsed"
                        Grid.Row="0"
                        Background="#22222222"
                        BorderBrush="#665B6B83"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="9"
                        Margin="0,0,0,8">
                    <DockPanel>
                        <Button Content="移除" Width="66" Height="28" DockPanel.Dock="Right" Click="RemoveAttachmentButton_Click" />
                        <TextBlock x:Name="AttachmentTextBlock" Text="No image" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PromptTextBox"
                             Height="62"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             PreviewKeyDown="PromptTextBox_PreviewKeyDown" />
                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Content="发送"
                            Click="SendButton_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
